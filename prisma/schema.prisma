// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Roles disponibles: admin | newApartament | guest ─────────────────────────
model User {
  id         Int         @id @default(autoincrement())
  email      String      @unique
  password   String      // bcrypt hash — nunca se devuelve en queries
  role       String      @default("guest")      // admin | newApartament | guest
  status     String      @default("active")     // active | inactive
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  apartments Apartment[] // apartamentos creados por este usuario
}

model Apartment {
  id               Int                @id @default(autoincrement())
  slug             String             @unique
  name             String
  description      String
  shortDescription String
  maxAdults        Int
  maxChildren      Int
  beds             Int                @default(2)
  bedrooms         Int
  bathrooms        Int
  pricePerNight    Float
  minStay          Int                @default(1)
  maxStay          Int                @default(30)
  isActive         Boolean            @default(true)
  airbnbIcsUrl     String?
  lastSyncAt       DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  // Relación con el usuario que creó el apartamento
  createdById      Int?
  createdBy        User?              @relation(fields: [createdById], references: [id], onDelete: SetNull)
  images           ApartmentImage[]
  amenities        ApartmentAmenity[]
  reservations     Reservation[]
  unavailableDates UnavailableDate[]
}

model UnavailableDate {
  id          Int       @id @default(autoincrement())
  apartmentId Int
  date        String    // YYYY-MM-DD
  source      String    @default("airbnb_ical")
  externalUid String?
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  @@unique([apartmentId, date, source])
  @@index([apartmentId, date])
}

model ApartmentImage {
  id          Int       @id @default(autoincrement())
  apartmentId Int
  url         String
  alt         String
  order       Int       @default(0)
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
}

model Amenity {
  id         Int                @id @default(autoincrement())
  name       String
  icon       String             @default("star")
  apartments ApartmentAmenity[]
}

model ApartmentAmenity {
  apartmentId Int
  amenityId   Int
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  amenity     Amenity   @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([apartmentId, amenityId])
}

model Reservation {
  id          Int       @id @default(autoincrement())
  apartmentId Int
  guestName   String
  guestEmail  String
  guestPhone  String
  checkIn     DateTime
  checkOut    DateTime
  adults      Int
  children    Int
  notes       String?
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  apartment   Apartment @relation(fields: [apartmentId], references: [id])
}
